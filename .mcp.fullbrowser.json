{
  "mcpServers": {
    "browserbase": {
      "type": "stdio",
      "command": "dotenvx",
      "args": [
        "run",
        "-f", "/media/sam/1TB/.env",
        "--",
        "npx",
        "-y",
        "@browserbasehq/mcp-server-browserbase"
      ],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {}
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"],
      "env": {}
    },
    "chrome-mcp-server": {
      "command": "node",
      "args": ["/home/sam/.npm-global/lib/node_modules/mcp-chrome-bridge/dist/mcp/mcp-server-stdio.js"],
      "env": {}
    }
  }
