# Canonical runtime template
# The legacy .env.template file is archived under archive/config/.
#
# Core service configuration
#
# The app reads these values directly via os.getenv(...). Source this file in your shell
# (or inject it via your process manager) before running uvicorn or the helper scripts.
HEATMAP_HOST=0.0.0.0
HEATMAP_PORT=8002
HEATMAP_API_URL=http://localhost:8002
HEATMAP_HYPERLIQUID_INFO_FALLBACK_URLS=http://localhost:3001/info,http://10.0.0.1:3001/info,https://api.hyperliquid.xyz/info
HEATMAP_HL_TOP_POSITION_SELECTION_MODE=global
HEATMAP_HL_TOP_POSITION_SCORE_MODE=notional
HEATMAP_HL_TOP_POSITION_CANDIDATE_POOL_TOP_N=250
HEATMAP_HL_TOP_POSITION_DISTANCE_FLOOR_BPS=25
HEATMAP_HL_TOP_POSITION_REQUIRE_SIDE_CONSISTENCY=false
HEATMAP_HL_TOP_POSITION_CONCENTRATION_SHARE_POWER=2.0
HEATMAP_HL_TOP_POSITION_CONCENTRATION_POSITIONS_PENALTY=0.2
HEATMAP_HL_TOP_POSITION_OBJECTIVE=default
HEATMAP_HL_TOP_POSITION_MIN_TARGET_SHARE=0.0
HEATMAP_HL_TOP_POSITION_MAX_POSITION_COUNT=0
# Optional per-symbol overrides, e.g.:
# The runtime wrapper `scripts/run-precompute-hl-sidecar.sh` currently defaults to:
# BTC -> balanced objective, top_n=350
# ETH -> concentration score, top_n=300, share_power=1.0, positions_penalty=0.1
# HEATMAP_HL_TOP_POSITION_OBJECTIVE_BTC=balanced
# HEATMAP_HL_TOP_POSITION_OBJECTIVE_BTC=shape_first
# HEATMAP_HL_TOP_POSITION_SCORE_MODE_BTC=concentration
# HEATMAP_HL_TOP_POSITION_SCORE_MODE_ETH=notional
# HEATMAP_HL_TOP_POSITION_TOP_N_BTC=350
# HEATMAP_HL_TOP_POSITION_TOP_N_ETH=300
# HEATMAP_HL_TOP_POSITION_MIN_TARGET_SHARE_BTC=0.7
# HEATMAP_HL_TOP_POSITION_MAX_POSITION_COUNT_BTC=3
# HEATMAP_HL_TOP_POSITION_CONCENTRATION_SHARE_POWER_BTC=1.0
# HEATMAP_HL_TOP_POSITION_CONCENTRATION_POSITIONS_PENALTY_ETH=0.1
HEATMAP_HL_LIVE_ENRICH_TOP_N=120
HEATMAP_HL_LIVE_ENRICH_RPM=180
HEATMAP_HL_LIVE_ENRICH_BATCH_SIZE=25
HEATMAP_HL_LIVE_ENRICH_CACHE_TTL_SECONDS=900
HEATMAP_DB_PATH=/media/sam/2TB-NVMe/liquidationheatmap_db/liquidations.duckdb
HEATMAP_DATA_DIR=/media/sam/3TB-WDC/binance-history-data-downloader/data
HEATMAP_PROJECT_ROOT=/media/sam/1TB/rektslug
HEATMAP_CCXT_CATALOG=/media/sam/1TB/ccxt-data-pipeline/data/catalog
HEATMAP_SHARED_ENV_FILE=/media/sam/1TB/.env
HEATMAP_SYMBOLS=BTCUSDT,ETHUSDT
HEATMAP_SYMBOLS_SHELL=BTCUSDT ETHUSDT
HEATMAP_LOG_DIR=/media/sam/1TB/rektslug/logs/ingestion

# Core container runtime (docker-compose.yml)
REKTSLUG_CORE_IMAGE=ghcr.io/gptcompany/rektslug-core:latest
REKTSLUG_DB_DIR=/media/sam/2TB-NVMe/liquidationheatmap_db
REKTSLUG_GAP_FILL_INTERVAL_SECONDS=300

# Optional container-side overrides for wrapper scripts
HEATMAP_CONTAINER_PROJECT_ROOT=/workspace/1TB/LiquidationHeatmap
HEATMAP_CONTAINER_DB_PATH=/workspace/2TB-NVMe/liquidationheatmap_db/liquidations.duckdb
HEATMAP_CONTAINER_DATA_DIR=/workspace/3TB-WDC/binance-history-data-downloader/data
HEATMAP_CONTAINER_PORT=8000
HEATMAP_CONTAINER_API_URL=http://host.docker.internal:8000

# QuestDB
# Use `questdb` for docker-compose networking; override to `localhost` when running the app directly on the host.
QUESTDB_HOST=questdb
QUESTDB_HTTP_PORT=9000
QUESTDB_PORT=9009
QUESTDB_PG_PORT=8812
QUESTDB_IMAGE=questdb/questdb:latest

# Internal API auth (gates prepare-for-ingestion, refresh-connections, gap-fill)
# If unset, the gate is disabled (open access for backward compat / dev).
REKTSLUG_INTERNAL_TOKEN=

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Signal Loop configuration
SIGNALS_ENABLED=true
SIGNAL_TOP_N=5

# API compatibility settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=120
LH_CACHE_TTL=300
LH_CACHE_MAX_SIZE=100

# Binance API (if using real-time streaming)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
