# Canonical runtime template
# The legacy .env.template file is archived under archive/config/.
#
# Core service configuration
#
# The app reads these values directly via os.getenv(...). Source this file in your shell
# (or inject it via your process manager) before running uvicorn or the helper scripts.
HEATMAP_HOST=0.0.0.0
HEATMAP_PORT=8002
HEATMAP_API_URL=http://localhost:8002
HEATMAP_DB_PATH=/media/sam/2TB-NVMe/liquidationheatmap_db/liquidations.duckdb
HEATMAP_DATA_DIR=/media/sam/3TB-WDC/binance-history-data-downloader/data
HEATMAP_PROJECT_ROOT=/media/sam/1TB/rektslug
HEATMAP_CCXT_CATALOG=/media/sam/1TB/ccxt-data-pipeline/data/catalog
HEATMAP_SHARED_ENV_FILE=/media/sam/1TB/.env
HEATMAP_SYMBOLS=BTCUSDT,ETHUSDT
HEATMAP_SYMBOLS_SHELL=BTCUSDT ETHUSDT
HEATMAP_LOG_DIR=/media/sam/1TB/rektslug/logs/ingestion

# Core container runtime (docker-compose.yml)
REKTSLUG_CORE_IMAGE=ghcr.io/gptcompany/rektslug-core:latest
REKTSLUG_DB_DIR=/media/sam/2TB-NVMe/liquidationheatmap_db
REKTSLUG_GAP_FILL_INTERVAL_SECONDS=300

# Optional container-side overrides for wrapper scripts
HEATMAP_CONTAINER_PROJECT_ROOT=/workspace/1TB/LiquidationHeatmap
HEATMAP_CONTAINER_DB_PATH=/workspace/2TB-NVMe/liquidationheatmap_db/liquidations.duckdb
HEATMAP_CONTAINER_DATA_DIR=/workspace/3TB-WDC/binance-history-data-downloader/data
HEATMAP_CONTAINER_PORT=8000
HEATMAP_CONTAINER_API_URL=http://host.docker.internal:8000

# Internal API auth (gates prepare-for-ingestion, refresh-connections, gap-fill)
# If unset, the gate is disabled (open access for backward compat / dev).
REKTSLUG_INTERNAL_TOKEN=

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Signal Loop configuration
SIGNALS_ENABLED=true
SIGNAL_TOP_N=5

# API compatibility settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=120
LH_CACHE_TTL=300
LH_CACHE_MAX_SIZE=100

# Binance API (if using real-time streaming)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
